generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  first_name   String
  last_name    String
  phone        String   @unique
  email        String   @unique
  password     String
  role         Role     @default(FARMER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  location     String?
  isActive     Boolean  @default(true)
  is_suspended Boolean  @default(false)

  // Relations
  cart          Cart?
  orders        Order[]
  products      Product[]
  notifications Notification[]
  searchHistory SearchHistory[]
  farmerOrders  OrderItem[]     @relation("FarmerOrderItems")
  orderReviews  OrderReview[] // ✅ ADD THIS LINE

  @@index([location])
  @@index([email])
  @@index([phone])
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@index([name])
}

model Product {
  id            Int           @id @default(autoincrement())
  name          String
  type          ProductType   @default(CROP)
  quantity      Decimal       @db.Decimal(10, 2)
  unit          String
  price         Decimal       @db.Decimal(10, 2)
  description   String?
  location      String?
  is_verified   Boolean       @default(false)
  is_featured   Boolean       @default(false)
  views         Int           @default(0)
  farmerId      Int
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  status        ProductStatus @default(AVAILABLE)
  categoryId    Int?
  tags          String?
  embeddingId   String?
  latitude      Float?
  longitude     Float?
  stockQuantity Int?           @default(0)

  // Relations
  category         Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  farmer           User              @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  cartItems        CartItem[]
  marketPrice      MarketPrice[]
  orderItems       OrderItem[]
  priceHistories   PriceHistory[]
  pricePredictions PricePrediction[]
  orderReviews     OrderReview[] // ✅ ADD THIS LINE

  @@index([name])
  @@index([status])
  @@index([farmerId])
  @@index([categoryId])
}

model PriceHistory {
  id        Int      @id @default(autoincrement())
  productId Int
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  source    String?
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([createdAt])
}

model PricePrediction {
  id             Int      @id @default(autoincrement())
  productId      Int
  predictedPrice Decimal  @db.Decimal(10, 2)
  predictedDate  DateTime
  createdAt      DateTime @default(now())
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([predictedDate])
}

model MarketPrice {
  id         String   @id @default(uuid())
  market     String
  price      Decimal  @db.Decimal(10, 2)
  unit       String
  source     String
  recordedAt DateTime @default(now())
  productId  Int
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([market])
  @@index([recordedAt])
}

model Cart {
  id        Int        @id @default(autoincrement())
  buyerId   Int        @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  buyer     User       @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@index([buyerId])
}

model CartItem {
  id        Int     @id @default(autoincrement())
  cartId    Int
  productId Int
  quantity  Decimal @db.Decimal(10, 2)
  unitPrice Decimal @db.Decimal(10, 2)
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

// ✅ UPDATED Order model with better fields
model Order {
  id              Int             @id @default(autoincrement())
  buyerId         Int
  totalAmount     Decimal         @db.Decimal(10, 2)
  status          OrderStatus     @default(PENDING)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deliveryAddress String?
  deliveryStatus  DeliveryStatus?
  notes           String?
  trackingNumber  String?
  shippingAddress String?
  cancelledAt     DateTime?

  // Relations
  buyer         User                 @relation(fields: [buyerId], references: [id], onDelete: Restrict)
  orderItems    OrderItem[]
  payment       Payment?
  statusHistory OrderStatusHistory[]
  notifications Notification[]
  review        OrderReview? // ✅ ADD THIS LINE (one-to-one with OrderReview)

  @@index([buyerId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
}

// ✅ UPDATED OrderItem model
model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Decimal @db.Decimal(10, 2)
  unitPrice Decimal @db.Decimal(10, 2) // Price at time of purchase

  // Relations
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  // ✅ Farmer relation for easy querying (who sells this item)
  farmerId Int? // Denormalized for performance
  farmer   User? @relation("FarmerOrderItems", fields: [farmerId], references: [id])

  @@unique([orderId, productId])
  @@index([orderId])
  @@index([productId])
  @@index([farmerId])
}

// ✅ Add OrderStatusHistory to track status changes
model OrderStatusHistory {
  id        Int          @id @default(autoincrement())
  orderId   Int
  oldStatus OrderStatus?
  newStatus OrderStatus
  changedBy Int // User ID who changed the status
  reason    String? // Reason for status change (e.g., cancellation reason)
  createdAt DateTime     @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

model Payment {
  id            Int           @id @default(autoincrement())
  orderId       Int           @unique
  amount        Decimal       @db.Decimal(10, 2)
  createdAt     DateTime      @default(now())
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  transactionId String? // ✅ External payment gateway transaction ID
  paidAt        DateTime? // ✅ When payment was completed
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@index([transactionId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  type      String   @default("general")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  orderId   Int? // ✅ Link notification to order
  productId Int? // Keep existing productId field

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([userId, isRead])
  @@index([orderId])
}

model SearchHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  query     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model SystemSetting {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  type        String   @default("string")
  description String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([key])
  @@map("SystemSetting")
}

// ✅ Add Review/Rating model for orders
model OrderReview {
  id        Int      @id @default(autoincrement())
  orderId   Int      @unique
  productId Int
  userId    Int // Buyer who wrote review
  rating    Int // 1-5 stars
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
  @@index([userId])
  @@index([rating])
}

enum Role {
  FARMER
  BUYER
  ADMIN
}

enum ProductType {
  CROP
  LIVESTOCK
}

enum ProductStatus {
  AVAILABLE
  SOLD_OUT
}

// ✅ UPDATED OrderStatus with more states
enum OrderStatus {
  PENDING // Order placed, waiting for farmer confirmation
  CONFIRMED // Farmer confirmed the order
  PROCESSING // Farmer is preparing the order
  SHIPPED // Order has been shipped
  DELIVERED // Order delivered successfully
  COMPLETED // Order completed (after delivery confirmation)
  CANCELLED // Order cancelled
  REFUNDED // Order refunded
}

enum DeliveryStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  FAILED
}

enum PaymentMethod {
  TELEBIRR
  MPESA
  CASH
  BANK_TRANSFER
}

enum PaymentStatus {
  SUCCESS
  FAILED
  PENDING
  REFUNDED
}
