generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int       @id @default(autoincrement())
  first_name String
  last_name  String
  phone      String   @unique
  email      String    @unique
  password   String
  role       Role      @default(FARMER)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  location    String?
  isActive   Boolean   @default(true)
  cart       Cart?
  orders     Order[]
  products   Product[]

  @@index([location])
  @@index([email])
  @@index([phone])
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id               Int               @id @default(autoincrement())
  name             String
  type             ProductType      @default(CROP)
  quantity         Decimal           @db.Decimal(10, 2)
  unit             String
  price            Decimal           @db.Decimal(10, 2)
  description      String?
  location         String?
  farmerId         Int
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  status           ProductStatus     @default(AVAILABLE)
  categoryId       Int?
  tags             String?
  embeddingId      String?
  latitude         Float?
  longitude        Float?
  cartItems        CartItem[]
  marketPrice      MarketPrice[]
  orderItems       OrderItem[]
  priceHistories   PriceHistory[]
  pricePredictions PricePrediction[]
  category         Category?         @relation(fields: [categoryId], references: [id])
  farmer           User              @relation(fields: [farmerId], references: [id])

  @@index([name])
  @@index([status])
  @@index([categoryId, status])
}

model PriceHistory {
  id        Int      @id @default(autoincrement())
  productId Int
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  source    String?
  product   Product  @relation(fields: [productId], references: [id])

  @@index([productId, createdAt])
}

model PricePrediction {
  id             Int      @id @default(autoincrement())
  productId      Int
  predictedPrice Decimal  @db.Decimal(10, 2)
  predictedDate  DateTime
  createdAt      DateTime @default(now())
  product        Product  @relation(fields: [productId], references: [id])
}

model MarketPrice {
  id         String   @id @default(uuid())
  market     String
  price      Decimal  @db.Decimal(10, 2)
  unit       String
  source     String
  recordedAt DateTime @default(now())
  productId  Int
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id])

  @@index([productId, market, recordedAt])
}

model Cart {
  id        Int        @id @default(autoincrement())
  buyerId   Int        @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  buyer     User       @relation(fields: [buyerId], references: [id])
  items     CartItem[]
}

model CartItem {
  id        Int     @id @default(autoincrement())
  cartId    Int
  productId Int
  quantity  Decimal @db.Decimal(10, 2)
  unitPrice Decimal @db.Decimal(10, 2)
  cart      Cart    @relation(fields: [cartId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model Order {
  id              Int             @id @default(autoincrement())
  buyerId         Int
  totalAmount     Decimal         @db.Decimal(10, 2)
  status          OrderStatus     @default(PENDING)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deliveryAddress String?
  deliveryStatus  DeliveryStatus?
  notes           String?
  buyer           User            @relation(fields: [buyerId], references: [id])
  orderItems      OrderItem[]
  payment         Payment?
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Decimal @db.Decimal(10, 2)
  unitPrice Decimal @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model Payment {
  id        Int           @id @default(autoincrement())
  orderId   Int           @unique
  amount    Decimal       @db.Decimal(10, 2)
  createdAt DateTime      @default(now())
  method    PaymentMethod
  status    PaymentStatus @default(PENDING)
  order     Order         @relation(fields: [orderId], references: [id])
}

enum Role {
  FARMER
  BUYER
  ADMIN
}

enum ProductType {
  CROP
  LIVESTOCK
}

enum ProductStatus {
  AVAILABLE
  SOLD_OUT
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum DeliveryStatus {
  IN_TRANSIT
  DELIVERED
  FAILED
}

enum PaymentMethod {
  TELEBIRR
  MPESA
  CASH
}

enum PaymentStatus {
  SUCCESS
  FAILED
  PENDING
  REFUNDED
}
